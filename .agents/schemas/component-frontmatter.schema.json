{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-kit.local/schemas/component-frontmatter.schema.json",
  "title": "AG Kit Component Frontmatter Contract",
  "description": "Documentation schema for component identity and SemVer metadata.",
  "type": "object",
  "required": ["name", "version"],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"},
    "description": {"type": "string"}
  },
  "additionalProperties": true
}
