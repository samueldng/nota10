{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ag-kit.local/schemas/manifest-lock.schema.json",
  "title": "AG Kit Component Lock",
  "type": "object",
  "required": ["schemaVersion", "kitVersion", "manifestSha256", "components"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "kitVersion": {"type": "string"},
    "manifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "components": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }
  },
  "additionalProperties": false
}
